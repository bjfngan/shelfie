# Discord — all found in Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_PUBLIC_KEY=        # General Information > Public Key
DISCORD_BOT_TOKEN=         # Bot > Token
DISCORD_APPLICATION_ID=    # General Information > Application ID
DISCORD_GUILD_ID=          # (optional) Server ID for instant command registration during dev

# Upstash Redis — auto-populated when you add the Upstash Redis integration in Vercel Dashboard
# Vercel Marketplace > Upstash Redis > Add Integration, then link to your project
# For local dev: run `vercel env pull` to download these into .env.local
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Books — unauthenticated requests work, but a key raises the rate limit
# Get one at https://console.cloud.google.com (Books API)
GOOGLE_BOOKS_API_KEY=      # optional
